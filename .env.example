# When this is true (or any key below is missing) the app runs in
# in-memory mock mode so paid services are never contacted.
EXPO_PUBLIC_USE_MOCKS=true

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Mapbox (display only — sign up later, free tier 25K loads/mo)
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.eyJ...

# OpenRouteService (free tier 2K requests/day)
EXPO_PUBLIC_ORS_API_KEY=your-ors-api-key
ORS_API_KEY=your-ors-api-key

# Stripe Connect Ireland (pack offer: waived fees on first $1k revenue)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...

# OneSignal (free tier 10k subscribers)
EXPO_PUBLIC_ONESIGNAL_APP_ID=your-app-id
ONESIGNAL_REST_API_KEY=your-rest-key

# Ops worker (deployed on a GitHub Student infra host of your choice)
OPS_TICK_MS=60000
